[Unit]
Description=Llama.cpp OpenAI API Server for Qwen 3.6
After=network.target

[Service]
Type=simple
User=kran
WorkingDirectory=/home/kran/Code/llama.cpp

# Replace paths with your absolute local paths
ExecStart=/home/kran/Code/llama.cpp/qwen3.6-27b.bash
# Handling failures and logs
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
