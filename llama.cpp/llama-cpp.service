[Unit]
Description=Llama.cpp OpenAI API Server
After=network.target

[Service]
Type=simple
User=kran
WorkingDirectory=/home/kran/Code/kran/llm-experiments/llama.cpp

ExecStart=/home/kran/Code/kran/llm-experiments/llama.cpp/llm.bash
# Handling failures and logs
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
